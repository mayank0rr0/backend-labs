generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String
  password  String
  documents Document[]
}

model Document {
  id        String     @id @default(uuid())
  filename  String
  filepath  String
  createdAt DateTime   @default(now())
  status    FileStatus @default(Uploaded)
  userId    String
  user      User       @relation(fields: [userId], references: [id])
}

enum FileStatus {
  Uploaded
  Processed
  Embedded
}
